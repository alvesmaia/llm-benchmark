# Saídas de execução — projetos gerados pelos agentes (cada um com seu próprio .git aninhado),
# logs brutos do CLI e snapshots de sessão. Mantidos apenas localmente.
runs/

# ZIPs exportados (app + prompt do juiz + resultados) para reavaliação por juiz externo.
exports/

# Base DNE oficial dos Correios (proprietária — nunca versionar)
dne/
*.DNE
DNE_*/
eDNE*/

# Fixture sintética do cenário inventory: o CSV é gerado por _generate.py (não versionar);
# só _generate.py e expected_metrics.json são commitados.
benchmark/inventory/fixtures/car_sales_sample/

# Python / uv
__pycache__/
*.py[cod]
.venv/
.uv/
*.egg-info/
.pytest_cache/
.ruff_cache/
build/
dist/

# Bancos gerados localmente
*.db
*.sqlite
*.sqlite3

# Logs de execução
*.log

# Diretórios temporários de teste do harness na raiz (_tmpapp, _stdintest, etc.)
/_*/

# SO / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
